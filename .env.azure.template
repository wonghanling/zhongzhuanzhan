# =============================================================================
# Boluo API Gateway - Azure VM environment template
# Copy this file to `.env.azure`, replace required placeholders, then run:
#   docker compose -f docker-compose.azure.yml up -d
# =============================================================================

# -----------------------------------------------------------------------------
# Required: New API database connection
# Azure Database for MySQL Flexible Server example:
#   user@server:password@tcp(server.mysql.database.azure.com:3306)/new-api?charset=utf8mb4&parseTime=true&loc=Local&tls=true
#
# Required if using local MySQL container instead:
#   root:<CHANGE_ME>@tcp(mysql:3306)/new-api?charset=utf8mb4&parseTime=true&loc=Local
# -----------------------------------------------------------------------------
SQL_DSN=<CHANGE_ME>

# -----------------------------------------------------------------------------
# Required: Redis connection
# Azure Cache for Redis example:
#   rediss://:<CHANGE_ME>@your-redis.redis.cache.windows.net:6380/0
#
# Required if using local Redis container instead:
#   redis://:<CHANGE_ME>@redis:6379/0
# -----------------------------------------------------------------------------
REDIS_CONN_STRING=<CHANGE_ME>

# -----------------------------------------------------------------------------
# Required: session secret
# Use a long random string. This is mandatory for stable login/session behavior.
# -----------------------------------------------------------------------------
SESSION_SECRET=<CHANGE_ME>

# -----------------------------------------------------------------------------
# Optional: single-VM local stack values
# Use these when starting `docker-compose.local-stack.yml`.
# They let New API talk to the local MariaDB and Redis services by container name.
# -----------------------------------------------------------------------------
LOCAL_DB_NAME=new-api
LOCAL_DB_USER=boluo
LOCAL_DB_PASSWORD=<CHANGE_ME>
LOCAL_DB_ROOT_PASSWORD=<CHANGE_ME>
LOCAL_SQL_DSN=boluo:<CHANGE_ME>@tcp(mysql:3306)/new-api?charset=utf8mb4&parseTime=true&loc=Local

LOCAL_REDIS_PASSWORD=<CHANGE_ME>
LOCAL_REDIS_CONN_STRING=redis://:<CHANGE_ME>@redis:6379/0

# -----------------------------------------------------------------------------
# Optional but recommended: brand/deployment preset injected at startup
# -----------------------------------------------------------------------------
BOLUO_SYSTEM_NAME=Boluo API Gateway
BOLUO_LOGO_URL=
BOLUO_FOOTER_HTML=Boluo API Gateway
BOLUO_DOCS_LINK=https://chinallmapi.com

# -----------------------------------------------------------------------------
# Optional but recommended: retry/health defaults for third-party aggregators
# -----------------------------------------------------------------------------
BOLUO_RETRY_TIMES=2
BOLUO_AUTO_DISABLE_STATUS_CODES=429,500-503
BOLUO_AUTO_RETRY_STATUS_CODES=429,500-503

# -----------------------------------------------------------------------------
# Optional: application networking
# If omitted, container still listens on 3000 and nginx on 80/443.
# -----------------------------------------------------------------------------
PORT=3000

# -----------------------------------------------------------------------------
# Optional: database pool tuning
# Defaults are already set in docker-compose.azure.yml; only override if needed.
# -----------------------------------------------------------------------------
# SQL_MAX_IDLE_CONNS=100
# SQL_MAX_OPEN_CONNS=1000
# SQL_MAX_LIFETIME=60

# -----------------------------------------------------------------------------
# Optional: cache/sync tuning
# -----------------------------------------------------------------------------
# SYNC_FREQUENCY=60
# CHANNEL_UPDATE_FREQUENCY=30
# BATCH_UPDATE_INTERVAL=5

# -----------------------------------------------------------------------------
# Optional: relay timeout tuning
# -----------------------------------------------------------------------------
# RELAY_TIMEOUT=0
# RELAY_IDLE_CONN_TIMEOUT=90
# STREAMING_TIMEOUT=300

# -----------------------------------------------------------------------------
# Optional: TLS behavior
# Leave false unless you intentionally need to skip upstream TLS verification.
# -----------------------------------------------------------------------------
# TLS_INSECURE_SKIP_VERIFY=false

# -----------------------------------------------------------------------------
# Optional: analytics / future use
# -----------------------------------------------------------------------------
# GOOGLE_ANALYTICS_ID=
# UMAMI_WEBSITE_ID=
# UMAMI_SCRIPT_URL=
